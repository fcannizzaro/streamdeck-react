{
  "name": "@fcannizzaro/streamdeck-react",
  "version": "0.1.1",
  "description": "Build Stream Deck plugins with React — render components directly to keys, dials, and touch screens",
  "type": "module",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "check-types": "tsc --noEmit",
    "test": "bun test ./src"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./rollup": {
      "types": "./dist/rollup.d.ts",
      "import": "./dist/rollup.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "streamdeck",
    "elgato",
    "react",
    "stream-deck",
    "plugin"
  ],
  "license": "MIT",
  "author": {
    "name": "Francesco Saverio Cannizzaro",
    "url": "https://github.com/fcannizzaro"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fcannizzaro/streamdeck-react.git",
    "directory": "packages/streamdeck-react"
  },
  "homepage": "https://streamdeckreact.fcannizzaro.com",
  "bugs": {
    "url": "https://github.com/fcannizzaro/streamdeck-react/issues"
  },
  "funding": {
    "type": "patreon",
    "url": "https://patreon.com/fcannizzaro"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.1",
    "@takumi-rs/core": "^0.69.5",
    "@takumi-rs/helpers": "^0.69.5",
    "react-reconciler": "^0.33.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-reconciler": "^0.33.0",
    "react-dom": "^19.2.4",
    "rollup": "^4.59.0",
    "vite": "^7.1.7",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "typescript": "^5"
  }
