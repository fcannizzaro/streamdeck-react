{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Actions": [
    {
      "Icon": "imgs/actions/display",
      "Name": "Atom Display",
      "States": [
        {
          "Image": "imgs/actions/display"
        }
      ],
      "UUID": "com.example.react-jotai.display",
      "Controllers": ["Keypad"],
      "Tooltip": "Shows the current Jotai value shared by a plugin wrapper."
    },
    {
      "Icon": "imgs/actions/increment",
      "Name": "Increment Atom",
      "States": [
        {
          "Image": "imgs/actions/increment"
        }
      ],
      "UUID": "com.example.react-jotai.increment",
      "Controllers": ["Keypad"],
      "Tooltip": "Writes to a shared Jotai atom."
    },
    {
      "Icon": "imgs/actions/reset",
      "Name": "Reset Atom",
      "States": [
        {
          "Image": "imgs/actions/reset"
        }
      ],
      "UUID": "com.example.react-jotai.reset",
      "Controllers": ["Keypad"],
      "Tooltip": "Resets the shared Jotai atom state."
    }
  ],
  "Author": "Francesco Saverio Cannizzaro",
  "Category": "React Jotai Sample",
  "CategoryIcon": "imgs/plugin-icon",
  "CodePath": "bin/plugin.mjs",
  "Description": "Sample plugin demonstrating shared cross-action state with Jotai and plugin wrappers.",
  "Icon": "imgs/plugin-icon",
  "Name": "React Jotai Sample",
  "Nodejs": {
    "Version": "20",
    "Debug": "--inspect=127.0.0.1:8092"
  },
  "OS": [
    {
      "Platform": "mac",
      "MinimumVersion": "13"
    },
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "UUID": "com.example.react-jotai",
  "Version": "0.0.0.1",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.9"
  }
}
